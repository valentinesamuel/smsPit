# Server
PORT=4300
UI_PORT=4301
NODE_ENV=development

# Database
DATABASE_URL=sqlite:./smspit.db

# Auth (optional — if set, all /api/* requests must include X-API-Key header)
API_KEY=

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=*

# Storage limits
MAX_MESSAGES=1000
AUTO_DELETE_AFTER=24h
PURGE_INTERVAL=1h

# Webhook (global fallback — can be overridden per-project)
WEBHOOK_URL=
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF=5s

# OTP Intelligence
OTP_DETECTION=true
OTP_MIN_LENGTH=4
OTP_MAX_LENGTH=8
OTP_EXTRACT_MODE=all
AUTO_TAG=true
